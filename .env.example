# ── Required ──────────────────────────────────────────────
# OpenAI API key (used for SQL generation, answers, and embeddings)
OPENAI_API_KEY=your_openai_key_here

# LangSmith tracing (observability / debugging) 
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=langgraph-sql-rag-agent

# ── Optional ──────────────────────────────────────────────
# Model to use. Must support Structured Outputs (gpt-4o-mini, gpt-4o).
OPENAI_MODEL=gpt-4o-mini
